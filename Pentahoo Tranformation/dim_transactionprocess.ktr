  <step>
    <name>date_time data</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Membuat fungsi untuk menghasilkan tanggal acak dalam rentang tertentu
var startDate = new Date("2024/01/10 00:00:00");
var endDate = new Date("2024/01/15 00:00:00");

// Fungsi untuk menghasilkan waktu acak dalam rentang yang ditentukan
function randomDate(start, end) {
    var date = new Date(start.getTime() + Math.random() * (end.getTime() - start.getTime()));
    return date;
}

// Menghasilkan tanggal acak untuk setiap baris
var randomDateGenerated = randomDate(startDate, endDate);

// Mengubah format tanggal ke "yyyy/MM/dd HH:mm:ss"
var formattedDate = (randomDateGenerated.getFullYear()) + "/" +
                    ((randomDateGenerated.getMonth() + 1) &lt; 10 ? '0' + (randomDateGenerated.getMonth() + 1) : (randomDateGenerated.getMonth() + 1)) + "/" +
                    (randomDateGenerated.getDate() &lt; 10 ? '0' + randomDateGenerated.getDate() : randomDateGenerated.getDate()) + " " +
                    (randomDateGenerated.getHours() &lt; 10 ? '0' + randomDateGenerated.getHours() : randomDateGenerated.getHours()) + ":" +
                    (randomDateGenerated.getMinutes() &lt; 10 ? '0' + randomDateGenerated.getMinutes() : randomDateGenerated.getMinutes()) + ":" +
                    (randomDateGenerated.getSeconds() &lt; 10 ? '0' + randomDateGenerated.getSeconds() : randomDateGenerated.getSeconds());

// Menetapkan hasil ke kolom "date_time"
date_time = formattedDate;
</jsScript_script>
      </jsScript>
    </jsScripts>
